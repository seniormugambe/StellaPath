# API Configuration (include /api so paths match the backend mount)
VITE_API_BASE_URL=http://localhost:3001/api

# X402 — optional defaults for the X402 page (https://x402.org)
VITE_X402_DEFAULT_RESOURCE_ID=demo
VITE_STELLAR_RAMP_ENABLED=true
VITE_STELLAR_RAMP_URL=https://stellar.org/learn/anchors
# Optional: query keys for your anchor’s hosted URL (defaults: account; amount omitted if empty)
# VITE_STELLAR_RAMP_ACCOUNT_PARAM=account
# VITE_STELLAR_RAMP_AMOUNT_PARAM=amount
VITE_CLIENT_PORTAL_URL=http://localhost:3000/client

# Stellar Network Configuration
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_PASSPHRASE="Test SDF Network ; September 2015"

# Soroban Configuration
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
VITE_SOROBAN_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract Addresses (will be populated after deployment)
VITE_TRANSACTION_CONTRACT_ADDRESS=
VITE_ESCROW_CONTRACT_ADDRESS=
VITE_INVOICE_CONTRACT_ADDRESS=

# App Configuration
VITE_APP_NAME="Stellar DApp"
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_TESTNET=true
VITE_ENABLE_MAINNET=false
VITE_ENABLE_DEBUG_MODE=true
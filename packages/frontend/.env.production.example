# Frontend Production Environment Configuration
# Copy to .env.production and fill in with actual values

# Backend API Base URL.
# Include /api because the backend mounts all application routes under /api.
VITE_API_BASE_URL=https://stellapathbackend.onrender.com/api

# Public client portal URL for generated invoice/client links.
VITE_CLIENT_PORTAL_URL=https://stellapath.onrender.com/client

# Feature Flags
VITE_ENABLE_WALLETCONNECT=false

# Optional: Analytics, error tracking, etc.
# VITE_SENTRY_DSN=https://your-sentry-key@sentry.io/project-id
# VITE_ANALYTICS_ID=your-ga-id
